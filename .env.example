# Impressum – required by German law (§ 5 DDG)
# These values are embedded at build time into the static HTML.
NEXT_PUBLIC_IMPRINT_NAME=Max Mustermann
NEXT_PUBLIC_IMPRINT_STREET=Musterstraße 1
NEXT_PUBLIC_IMPRINT_CITY=12345 Musterstadt
NEXT_PUBLIC_IMPRINT_EMAIL=kontakt@opensolarcheck.de

# Umami Analytics (optional – without these values, no tracking is loaded)
NEXT_PUBLIC_UMAMI_ENABLED=false
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://analytics.your-domain.de
